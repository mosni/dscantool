# Copy this to settings.py and fill in actual values,
# OR use the Docker/env-var setup (see .env.example).
# For Docker deployment settings.py is already configured to read from env.
# This file is kept for reference only.
#
# Minimum required env vars:
#   SECRET_KEY, DB_PASSWORD
# Optional (have defaults):
#   DEBUG (default False), ALLOWED_HOSTS (default dscan.nimos.ws),
#   DB_NAME (default dscantool), DB_USER (default dscantool),
#   DB_HOST (default mariadb), DB_PORT (default 3306)
